# ============================================
# 长信宫灯系统环境变量配置
# ============================================
# 复制此文件为 .env 后修改配置

# ============================================
# PostgreSQL / TimescaleDB
# ============================================
POSTGRES_DB=changxin_gongdeng
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# 应用数据库连接（后端使用）
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/changxin_gongdeng

# ============================================
# Redis
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# ============================================
# MQTT Broker (Mosquitto)
# ============================================
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_WS_PORT=9001
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=gongdeng
MQTT_TOPIC_ALERT=gongdeng/alerts
MQTT_TOPIC_DATA=gongdeng/sensor

# ============================================
# 告警阈值
# ============================================
PM25_THRESHOLD_WARNING=75.0
PM25_THRESHOLD_CRITICAL=150.0
FLUE_VELOCITY_MIN=0.1
FLUE_TEMPERATURE_MAX=200.0

# ============================================
# 模拟器配置
# ============================================
# 基本配置
SIMULATOR_LAMP_ID=1
SIMULATOR_ENABLE_MODBUS=true
SIMULATOR_ENABLE_HTTP=true
SIMULATOR_REPORT_INTERVAL=60

# 实验参数（可动态调整）
SIMULATOR_FUEL_TYPE=animal_fat       # animal_fat | sesame_oil | beeswax | mineral_oil | tallow
SIMULATOR_AIR_CHANGE_RATE=1.0        # 换气率 0-20 ACH（次/小时）
SIMULATOR_OUTDOOR_PM25=25.0          # 室外PM2.5基准浓度 μg/m³
SIMULATOR_INJECT_ANOMALIES=true      # 是否注入烟道堵塞等随机异常

# ============================================
# Modbus TCP
# ============================================
MODBUS_HOST=0.0.0.0
MODBUS_PORT=502

# ============================================
# FastAPI 应用
# ============================================
API_PORT=8000
DEBUG=false
APP_NAME="长信宫灯烟道流体仿真与室内空气质量分析系统"
DEFAULT_FUEL_TYPE=animal_fat

# ============================================
# Gunicorn
# ============================================
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info
GUNICORN_MAX_REQUESTS=10000
GUNICORN_MAX_REQUESTS_JITTER=1000

# ============================================
# 房间与网格参数
# ============================================
ROOM_SIZE_X=10.0
ROOM_SIZE_Y=8.0
ROOM_SIZE_Z=3.0
GRID_RESOLUTION=5
